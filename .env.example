# Copy this file to .env and fill in real values.
# .env is gitignored and will never be committed.

# ── PostgreSQL (used by docker-compose) ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inventory_db

# ── Backend ───────────────────────────────────────────────────────────────────
# Local Docker Compose — derived from the values above automatically:
DATABASE_URL=postgresql://postgres:changeme@db:5432/inventory_db

# Production (Render / Railway) — paste the connection string from your DB dashboard:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-64-char-random-string

# Comma-separated list of allowed frontend origins
# Local:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app.onrender.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave empty when using Docker Compose (nginx proxies API calls)
# Set to your backend URL when deploying frontend separately (Vercel / Render Static Site)
# VITE_API_URL=https://your-backend.onrender.com
